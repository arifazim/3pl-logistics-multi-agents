# AP2 payment demo - SANDBOX/TEST credentials only. Copy to .env (which is gitignored).
# The system defaults to a safe MockProcessor; real rails are used ONLY when
# ALLOW_LIVE_PAYMENTS=1 AND valid test/sandbox keys are present. Live keys are hard-blocked.

# Set to 1 to enable Stripe test-mode + Plaid sandbox rails. Leave unset for mock mode.
ALLOW_LIVE_PAYMENTS=

# Stripe - TEST key only (must start with sk_test_). sk_live_ is rejected.
STRIPE_API_KEY=your_stripe_secret_key_here
# Optional: map vendor_id -> Stripe Connect *test* connected account for real transfers.
# Without this, a charge is created without routing to a vendor account.
# Format: V001=acct_xxx,V002=acct_yyy
STRIPE_VENDOR_ACCOUNT_MAP=

# Funding method: "card" (default, Stripe test card pm_card_visa) or
# "ach" (funds from a Plaid-linked bank account via a Stripe bank-account token - no card).
PAYMENT_METHOD=card

# Plaid - SANDBOX only. PLAID_ENV=production is rejected.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
